generator client {
    provider = "prisma-client-js"
    output   = "../src/generated/prisma"
}

datasource db {
    provider = "mysql"
}

// User
model User {
    id               String    @id @default(uuid())
    username         String?   @unique
    displayName      String?   @map("display_name")
    email            String    @unique
    avatar           String?   @db.Text
    password         String?
    role             Role      @default(user)
    googleProviderId String?   @map("google_provider_id")
    verifyAt         DateTime? @map("verify_at")
    createdAt        DateTime  @default(now()) @map("created_at")
    updatedAt        DateTime  @default(now()) @map("updated_at")

    flows             Flow[]
    flowShares        FlowShare[]
    notifications     Notification[]
    fallback          FlowFallback?
    pages             Page[]
    chatConversations ChatConversation[]

    userFlowStates     UserFlowState[]     @relation("Owner_UserFlowState")
    verificationTokens VerificationToken[]
    flowShareDowloads  FlowShareDowload[]
    flowShareLikes     FlowShareLike[]
    flowShareSaves     FlowShareSave[]
    flowShareComments  FlowShareComment[]
    posts              Posts[]

    @@map("users")
}

enum Role {
    admin
    user
}

model VerificationToken {
    id        String    @id @default(uuid())
    type      TokenType
    token     String    @unique @db.VarChar(255)
    email     String?
    expiresAt DateTime  @map("expires_at")
    userId    String    @map("user_id")
    user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@map("verification_tokens")
}

enum TokenType {
    verify_email
    reset_password
    refresh_token
}

model Flow {
    id              String     @id @default(uuid())
    userId          String     @map("user_id")
    pageId          String?    @map("page_id")
    name            String     @map("name")
    description     String?
    status          FlowStatus @default(active)
    logicJson       Json?      @map("logic_json")
    layoutJson      Json?      @map("layout_json")
    timeoutDuration String     @default("10s") @map("timeout_duration")
    startNodeId     String?    @map("start_node_id")
    timeoutJson     Json?      @map("timeout_json")
    createdAt       DateTime   @default(now()) @map("created_at")
    updatedAt       DateTime   @default(now()) @map("updated_at")

    user   User            @relation(fields: [userId], references: [id], onDelete: Cascade)
    page   Page?           @relation(fields: [pageId], references: [id], onDelete: SetNull)
    states UserFlowState[]
    shares FlowShare[]

    @@map("flows")
}

enum FlowStatus {
    active
    inactive
}

model Page {
    id String @id @default(uuid()) @map("id")

    userId String @map("user_id")

    pageUid String @unique @map("page_uid")

    name   String  @map("name")
    avatar String? @map("avatar")

    pageAccessToken String @map("page_access_token") @db.Text

    status PageStatus @default(active)

    createdAt DateTime @default(now()) @map("created_at")
    updatedAt DateTime @updatedAt @map("updated_at")

    user  User   @relation(fields: [userId], references: [id], onDelete: Cascade)
    flows Flow[]

    @@map("pages")
}

enum PageStatus {
    active
    inactive
    isExpired
}

enum UserFlowStatus {
    running
    pending
    cancelled
    completed
}

model UserFlowState {
    id             String         @id @default(uuid()) @map("id")
    platformUserId String         @map("platform_user_id")
    ownerUserId    String         @map("owner_user_id")
    flowId         String         @map("flow_id")
    pageId         String         @map("page_id")
    currentStep    String         @map("current_step")
    stepHistory    Json?          @map("step_history")
    variables      Json?          @map("variables")
    status         UserFlowStatus @default(running) @map("status")
    createdAt      DateTime       @default(now()) @map("created_at")
    updatedAt      DateTime       @updatedAt @map("updated_at")

    owner User @relation(fields: [ownerUserId], references: [id], name: "Owner_UserFlowState", onDelete: Cascade)
    flow  Flow @relation(fields: [flowId], references: [id], onDelete: Cascade)

    @@map("user_flow_states")
}

model FlowShare {
    id          String          @id @default(uuid()) @map("id")
    flowId      String          @map("flow_id")
    userId      String          @map("user_id")
    name        String
    description String?
    thumbnail   String?
    content     String?         @db.Text
    status      FlowShareStatus @default(active)
    createdAt   DateTime        @default(now()) @map("created_at")
    updatedAt   DateTime        @default(now()) @updatedAt @map("updated_at")

    flow              Flow               @relation(fields: [flowId], references: [id])
    user              User               @relation(fields: [userId], references: [id], onDelete: Cascade)
    flowShareDowloads FlowShareDowload[]
    flowShareLikes    FlowShareLike[]
    flowShareSaves    FlowShareSave[]
    flowShareComments FlowShareComment[]

    @@map("flow_shares")
}

enum FlowShareStatus {
    active
    inactive
}

model FlowShareDowload {
    id          String   @id @default(uuid())
    flowShareId String   @map("flow_share_id")
    userId      String   @map("user_id")
    createdAt   DateTime @default(now()) @map("created_at")

    flowShare FlowShare @relation(fields: [flowShareId], references: [id], onDelete: Cascade)
    user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@index([flowShareId])
    @@map("flow_share_dowloads")
}

model FlowShareComment {
    id          String   @id @default(uuid())
    flowShareId String   @map("flow_share_id")
    userId      String   @map("user_id")
    comment     String   @map("comment")
    parentId    String?  @map("parent_id")
    createdAt   DateTime @default(now()) @map("created_at")
    updatedAt   DateTime @default(now()) @updatedAt @map("updated_at")

    flowShare FlowShare @relation(fields: [flowShareId], references: [id], onDelete: Cascade)
    user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

    parent FlowShareComment? @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)

    replies FlowShareComment[] @relation("CommentReplies")

    @@map("flow_share_comments")
}

model FlowShareLike {
    id          String   @id @default(uuid())
    flowShareId String
    userId      String
    createdAt   DateTime @default(now())

    flowShare FlowShare @relation(fields: [flowShareId], references: [id], onDelete: Cascade)
    user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@unique([flowShareId, userId])
    @@map("flow_share_likes")
}

model FlowShareSave {
    id          String   @id @default(uuid())
    flowShareId String
    userId      String
    createdAt   DateTime @default(now())

    flowShare FlowShare @relation(fields: [flowShareId], references: [id], onDelete: Cascade)
    user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@unique([flowShareId, userId])
    @@map("flow_share_saves")
}

model Notification {
    id        String           @id @default(uuid()) @map("id")
    userId    String           @map("user_id")
    type      NotificationType @map("type")
    message   String           @map("message")
    avatar    String?          @map("avatar")
    relatedId String           @map("related_id")
    read      Boolean          @default(false) @map("read")
    createdAt DateTime         @default(now()) @map("created_at")
    updatedAt DateTime         @default(now()) @map("updated_at")

    user User @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@map("notifications")
}

enum NotificationType {
    comment
    reply
    download
    flow_done
    flow_cancelled
    new_user
    chat_message
}

enum TimeoutUnit {
    second
    minute
    hour
    day
}

model FlowFallback {
    id String @id @default(uuid()) @map("id")

    userId String @unique @map("user_id")
    user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

    timeoutDuration Int         @map("timeout_duration")
    timeoutUnit     TimeoutUnit @map("timeout_unit")

    fallbackMessage String @map("fallback_message") @db.Text

    createdAt DateTime @default(now()) @map("created_at")
    updatedAt DateTime @updatedAt @map("updated_at")

    @@map("flow_fallbacks")
}

model Posts {
    id         String @id @default(uuid())
    authorId   String @map("author_id")
    categoryId String @map("category_id")

    slug        String      @unique
    title       String
    description String
    content     String      @map("content") @db.Text
    thumbnail   String      @map("thumbnail")
    status      PostsStatus @default(active) @map("status")

    category PostCategories @relation(fields: [categoryId], references: [id], onDelete: Restrict)
    author   User           @relation(fields: [authorId], references: [id], onDelete: Cascade)

    createdAt DateTime @default(now()) @map("created_at")
    updatedAt DateTime @updatedAt @map("updated_at")

    @@map("posts")
}

model PostCategories {
    id   String @id @default(uuid())
    name String @unique
    slug String @unique

    posts Posts[]

    createdAt DateTime @default(now()) @map("created_at")
    updatedAt DateTime @updatedAt @map("updated_at")

    @@map("post_categories")
}

enum PostsStatus {
    active
    inactive
}

model ChatConversation {
    id     String @id @default(uuid()) @map("id")
    userId String @unique @map("user_id")

    lastMessage   String?   @map("last_message")
    lastMessageAt DateTime? @map("last_message_at")

    createdAt DateTime @default(now()) @map("created_at")
    updatedAt DateTime @updatedAt @map("updated_at")

    user     User              @relation(fields: [userId], references: [id], onDelete: Cascade)
    messages ChatLiveMessage[]

    @@index([userId])
    @@map("chat_conversations")
}

model ChatLiveMessage {
    id             String @id @default(uuid()) @map("id")
    conversationId String @map("conversation_id")

    sender  ChatSender      @map("sender")
    type    ChatMessageType @map("type")
    content String          @map("content") @db.Text

    revokedAt DateTime? @map("revoked_at")
    readAt    DateTime? @map("read_at")

    createdAt DateTime @default(now()) @map("created_at")

    conversation ChatConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

    @@index([conversationId])
    @@index([sender])
    @@map("chat_live_messages")
}

enum ChatSender {
    user
    admin
}

enum ChatMessageType {
    text
    image
    video
}
