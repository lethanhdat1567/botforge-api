generator client {
    provider = "prisma-client-js"
}

datasource db {
    provider = "mysql"
}

model User {
    id               String    @id @default(uuid())
    username         String?   @unique
    displayName      String?   @map("display_name")
    email            String    @unique
    avatar           String?   @db.Text
    password         String?
    role             Role      @default(user)
    googleProviderId String?   @map("google_provider_id")
    verifyAt         DateTime? @map("verify_at")
    createdAt        DateTime  @default(now()) @map("created_at")
    updatedAt        DateTime  @default(now()) @map("updated_at")

    flows         Flow[]
    flowShares    FlowShare[]
    notifications Notification[]

    verificationTokens VerificationToken[]
    flowShareDowloads  FlowShareDowload[]
    flowShareLikes     FlowShareLike[]
    flowShareSaves     FlowShareSave[]
    flowShareComments  FlowShareComment[]
    posts              Posts[]
    conversations      Conversation[]
    messagesSent       Message[]             @relation("MessageSenderUser")
    facebookAuth       FacebookAuth?

    @@map("users")
}

enum Role {
    admin
    user
}

model FacebookAuth {
    id                 String    @id @default(uuid())
    facebookProviderId String    @unique @map("facebook_provider_id")
    fbAccessToken      String    @map("fb_access_token") @db.Text
    fbTokenExpiresAt   DateTime? @map("fb_token_expires_at")

    userId String @unique @map("user_id")
    user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

    createdAt DateTime @default(now()) @map("created_at")
    updatedAt DateTime @updatedAt @map("updated_at")

    @@map("facebook_auths")
}

model VerificationToken {
    id        String    @id @default(uuid())
    type      TokenType
    token     String    @unique @db.VarChar(255)
    email     String?
    expiresAt DateTime  @map("expires_at")
    userId    String    @map("user_id")
    user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@map("verification_tokens")
}

enum TokenType {
    verify_email
    reset_password
    refresh_token
}

model Flow {
    id              String     @id @default(uuid())
    userId          String     @map("user_id")
    name            String     @map("name")
    status          FlowStatus @default(inactive)
    logicJson       Json?      @map("logic_json")
    layoutJson      Json?      @map("layout_json")
    timeoutDuration String     @default("10s") @map("timeout_duration")
    startNodeId     String?    @map("start_node_id")
    timeoutJson     Json?      @map("timeout_json")
    createdAt       DateTime   @default(now()) @map("created_at")
    updatedAt       DateTime   @default(now()) @updatedAt @map("updated_at")

    user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
    shares      FlowShare[]
    flowRecords FlowRecord[]
    page        Page?
    flowShareDownloadClones FlowShareDowload[] @relation("FlowShareDownloadClone")

    @@unique([userId, name])
    @@map("flows")
}

model Page {
    id              String @id @default(uuid()) @map("id")
    pageUid         String @map("page_uid")
    pageAccessToken String @map("page_access_token") @db.Text
    flowId          String @unique @map("flow_id")
    flow            Flow   @relation(fields: [flowId], references: [id], onDelete: Cascade)

    createdAt DateTime @default(now()) @map("created_at")
    updatedAt DateTime @updatedAt @map("updated_at")

    @@map("pages")
}

enum FlowStatus {
    active
    inactive
}

model FlowShare {
    id          String          @id @default(uuid()) @map("id")
    flowId      String          @map("flow_id")
    userId      String          @map("user_id")
    name        String
    description String?			@db.Text
    thumbnail   String?
    content     String?         @db.Text
    status      FlowShareStatus @default(active)
    createdAt   DateTime        @default(now()) @map("created_at")
    updatedAt   DateTime        @default(now()) @updatedAt @map("updated_at")

    flow              Flow                @relation(fields: [flowId], references: [id])
    user              User                @relation(fields: [userId], references: [id], onDelete: Cascade)
    flowShareDowloads FlowShareDowload[]
    flowShareLikes    FlowShareLike[]
    flowShareSaves    FlowShareSave[]
    flowShareComments FlowShareComment[]
    flowShareCategory FlowShareCategory[]

    @@map("flow_shares")
}

enum FlowShareStatus {
    active
    inactive
}

model FlowShareCategory {
    id   String @id @default(uuid())
    name String @unique
    slug String @unique

    flowShares FlowShare[]

    @@map("categories")
}

model FlowShareDowload {
    id                        String    @id @default(uuid())
    flowShareId               String    @map("flow_share_id")
    userId                    String    @map("user_id")
    clonedFlowId              String?   @map("cloned_flow_id")
    lastKnownCloneUpdatedAt   DateTime? @map("last_known_clone_updated_at")
    createdAt                 DateTime  @default(now()) @map("created_at")

    flowShare  FlowShare @relation(fields: [flowShareId], references: [id], onDelete: Cascade)
    user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
    clonedFlow Flow?     @relation("FlowShareDownloadClone", fields: [clonedFlowId], references: [id], onDelete: SetNull)

    @@index([flowShareId])
    @@index([clonedFlowId])
    @@map("flow_share_dowloads")
}

model FlowShareComment {
    id          String   @id @default(uuid())
    flowShareId String   @map("flow_share_id")
    userId      String   @map("user_id")
    comment     String   @map("comment")
    parentId    String?  @map("parent_id")
    createdAt   DateTime @default(now()) @map("created_at")
    updatedAt   DateTime @default(now()) @updatedAt @map("updated_at")

    flowShare FlowShare @relation(fields: [flowShareId], references: [id], onDelete: Cascade)
    user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

    parent FlowShareComment? @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)

    replies FlowShareComment[] @relation("CommentReplies")

    @@map("flow_share_comments")
}

model FlowShareLike {
    id          String   @id @default(uuid())
    flowShareId String
    userId      String
    createdAt   DateTime @default(now())

    flowShare FlowShare @relation(fields: [flowShareId], references: [id], onDelete: Cascade)
    user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@unique([flowShareId, userId])
    @@map("flow_share_likes")
}

model FlowShareSave {
    id          String   @id @default(uuid())
    flowShareId String
    userId      String
    createdAt   DateTime @default(now())

    flowShare FlowShare @relation(fields: [flowShareId], references: [id], onDelete: Cascade)
    user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@unique([flowShareId, userId])
    @@map("flow_share_saves")
}

model Notification {
    id        String           @id @default(uuid())
    userId    String           @map("user_id")
    type      NotificationType
    message   String
    thumbnail String?
    relatedId String           @map("related_id")
    read      Boolean          @default(false)
    createdAt DateTime         @default(now()) @map("created_at")
    updatedAt DateTime         @default(now()) @map("updated_at")

    user User @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@map("notifications")
}

enum NotificationType {
    comment
    reply
    download
    new_user
    chat_message
}

model Posts {
    id         String @id @default(uuid())
    authorId   String @map("author_id")
    categoryId String @map("category_id")

    slug        String      @unique
    title       String
    description String      @db.Text
    content     String      @map("content") @db.Text
    thumbnail   String      @map("thumbnail")
    status      PostsStatus @default(active) @map("status")

    category PostCategories @relation(fields: [categoryId], references: [id], onDelete: Restrict)
    author   User           @relation(fields: [authorId], references: [id], onDelete: Cascade)

    createdAt DateTime @default(now()) @map("created_at")
    updatedAt DateTime @updatedAt @map("updated_at")

    @@map("posts")
}

model PostCategories {
    id   String @id @default(uuid())
    name String @unique
    slug String @unique

    posts Posts[]

    createdAt DateTime @default(now()) @map("created_at")
    updatedAt DateTime @updatedAt @map("updated_at")

    @@map("post_categories")
}

enum PostsStatus {
    active
    inactive
}

model AnonymousParticipant {
    id          String   @id
    displayName String?  @map("display_name")
    createdAt   DateTime @default(now()) @map("created_at")
    updatedAt   DateTime @updatedAt @map("updated_at")

    conversations Conversation[]
    messages      Message[]

    @@map("anonymous_participants")
}

model Conversation {
    id                     String             @id @default(uuid())
    userId                 String?
    guestName              String?
    anonymousParticipantId String?            @map("anonymous_participant_id")
    status                 ConversationStatus @default(open)
    messages               Message[]
    createdAt              DateTime           @default(now())
    updatedAt              DateTime           @updatedAt

    user                 User?                 @relation(fields: [userId], references: [id], onDelete: SetNull)
    anonymousParticipant AnonymousParticipant? @relation(fields: [anonymousParticipantId], references: [id], onDelete: SetNull)

    @@index([userId])
    @@index([anonymousParticipantId])
}

enum ConversationStatus {
    open
    closed
}

model Message {
    id             String @id @default(uuid())
    conversationId String

    role        Role      @default(user)
    readByAdmin Boolean   @default(false)
    readByUser  Boolean   @default(false)
    revokedAt   DateTime?

    content String? @db.Text

    fileUrl String?

    senderUserId String? @map("sender_user_id")
    senderUser   User?   @relation("MessageSenderUser", fields: [senderUserId], references: [id], onDelete: SetNull)

    senderAnonymousId String?               @map("sender_anonymous_id")
    senderAnonymous   AnonymousParticipant? @relation(fields: [senderAnonymousId], references: [id], onDelete: SetNull)

    conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

    createdAt DateTime @default(now())

    @@index([conversationId])
    @@index([senderUserId])
    @@index([senderAnonymousId])
}

model FlowRecord {
    id String @id @default(uuid())

    senderId String @map("sender_id")
    flowId   String @map("flow_id")

    currentNodeId String @map("current_node_id")

    variables Json?            @map("variables")
    status    FlowRecordStatus @default(running)

    lastInteraction    DateTime  @default(now()) @updatedAt @map("last_interaction")
    errorLog           String?   @map("error_log") @db.Text
    waitingForVariable Json?     @map("waiting_for_variable")
    expiresAt          DateTime? @map("expires_at")

    flow Flow @relation(fields: [flowId], references: [id], onDelete: Cascade)

    @@index([status])
    @@map("flow_records")
}

enum FlowRecordStatus {
    running
    pending
    processing
    completed
    cancelled
    error
}

model Queue {
    id        String      @id @default(uuid())
    type      String
    payload   Json
    status    QueueStatus
    createdAt DateTime    @default(now())
    updatedAt DateTime    @updatedAt

    @@map("queues")
}

enum QueueStatus {
    pending
    processing
    completed
    error
}
