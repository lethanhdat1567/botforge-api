# =============================================================================
# Botforge API — environment template
# Copy to `.env` and replace placeholder values. Never commit real secrets.
# =============================================================================

# -----------------------------------------------------------------------------
# App config
# -----------------------------------------------------------------------------
# NODE_ENV: "development" | "production". Affects CORS (localhost allowed only in dev).
NODE_ENV=development

# PORT: HTTP port for Express and Socket.io (same Node process).
PORT=8000

# BASE_URL: Public origin of this API (used in docs/comments; set to your deployed URL).
BASE_URL=http://localhost:8000

# FRONTEND_URL: Dashboard origin. Used by Express CORS allowlist (normalized, no trailing slash).
FRONTEND_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
# DATABASE_URL: Connection string for Prisma CLI (migrate, prisma.config.ts). MySQL format, e.g.:
# mysql://USER:PASSWORD@HOST:3306/DATABASE
DATABASE_URL="mysql://user:password@localhost:3306/botforge"

# The following are used at runtime by @prisma/adapter-mariadb (src/config/prisma.ts)
# and by the scheduled mysqldump backup (src/schedules/backupDB.ts).
DATABASE_HOST=localhost
DATABASE_USER=user
DATABASE_PASSWORD=password
DATABASE_NAME=botforge

# -----------------------------------------------------------------------------
# Facebook API (Messenger / Meta app)
# -----------------------------------------------------------------------------
# FACEBOOK_APP_ID / FACEBOOK_APP_SECRET: Meta app credentials (OAuth, app-level calls).
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=

# VERIFY_TOKEN: Must match the Verify Token in Meta App Dashboard → Webhooks.
# Used when Meta sends GET ...?hub.mode=subscribe&hub.verify_token=...
VERIFY_TOKEN=

# Page access tokens are stored per page in the database after OAuth (not env vars).

# -----------------------------------------------------------------------------
# JWT / Auth
# -----------------------------------------------------------------------------
# Secrets for signing access and refresh tokens (use long random strings in production).
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=

# Optional token lifetimes (jsonwebtoken `expiresIn` format, e.g. 1h, 7d, 3600).
ACCESS_EXPIRES=1h
REFRESH_EXPIRES=7d

# -----------------------------------------------------------------------------
# Socket.io
# -----------------------------------------------------------------------------
# No dedicated SOCKET_* variables are read in this codebase. Socket.io listens on the
# same HTTP server as Express; clients typically connect to ws:// or wss:// host:PORT.
# REST API CORS is constrained via FRONTEND_URL; engine CORS is configured in src/socket/index.ts.

# -----------------------------------------------------------------------------
# Email (SMTP) — used by the queue worker (npm run queue)
# -----------------------------------------------------------------------------
MAIL_HOST=
MAIL_PORT=587
MAIL_USER=
MAIL_PASSWORD=
MAIL_FROM="Botforge <noreply@example.com>"

# -----------------------------------------------------------------------------
# Google — OAuth client + Drive folder for scheduled DB backups (npm run schedule)
# -----------------------------------------------------------------------------
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CLIENT_REFRESH_TOKEN=
GOOGLE_DRIVE_FOLDER_ID=

# -----------------------------------------------------------------------------
# Firebase Admin — push / admin SDK (src/config/firebase.ts)
# -----------------------------------------------------------------------------
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
# FIREBASE_PRIVATE_KEY: PEM with literal \n escaped for .env (or single-line JSON key field).
FIREBASE_PRIVATE_KEY=
